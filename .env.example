# LLM 분류기 환경변수
# 모두 선택 사항. 미설정 시 아래 default 사용.

# 브라우저에서 LLM 호출 시 사용할 base URL (Ollama host root).
# 어댑터는 native /api/chat 으로 호출 (think:false 로 reasoning trace 제거).
# default: '/api/llm' (vite proxy 가 host:11434 로 forward)
# OpenAI 등 외부 API 직접 호출 시에는 어댑터 endpoint/응답 schema 도 OpenAI 호환으로 바꿀 것.
# VITE_LLM_BASE_URL=/api/llm

# 사용할 모델. Ollama 면 `ollama pull <model>` 로 미리 받아둘 것.
# default: 'qwen2.5:3b'
# 한국어 정확도 높이려면 'qwen2.5:7b' 또는 'gemma2:9b' 권장.
# VITE_LLM_MODEL=qwen2.5:3b

# Bearer 토큰. Ollama 는 무시함. OpenAI 사용 시 sk-... 입력.
# default: 'ollama'
# VITE_LLM_API_KEY=ollama

# vite proxy 가 forward 할 Ollama 엔드포인트 (server-side).
# default: 'http://localhost:11434'
# OLLAMA_URL=http://localhost:11434

# LLM 호출 timeout (ms). plan §4.7 production 기준은 5000.
# 로컬 8B 모델 cold start (~7초) 흡수하려면 dev 에선 늘릴 것.
# default: 5000
# VITE_LLM_TIMEOUT_MS=30000

# 'true' 면 LLM 대신 mockClassifier 사용 (오프라인 dev 용).
# VITE_USE_MOCK_CLASSIFIER=true
